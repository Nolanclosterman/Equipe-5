{
  "name": "chatbot-temp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next/cache && next dev",
    "build": "next build",
    "clean": "rm -rf .next/",
    "vercel-build": "npm rebuild better-sqlite3 --build-from-source && next build",
    "start": "if [ ! -d .next ]; then npm run build; fi && next start",
    "lint": "eslint",
    "eval": "node evals/run-evals.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "better-sqlite3": "^12.10.0",
    "fuse.js": "^7.4.2",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
